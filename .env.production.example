# Production environment for docker-compose.prod.yml.
# Copy to .env.production on the server and fill in real values. NEVER commit
# the filled-in file. Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# Public hostname (DuckDNS subdomain or your own domain). No scheme, no slash.
DOMAIN=threadspace.duckdns.org

# Django
SECRET_KEY=change-me-to-a-50-char-random-string
POSTGRES_USER=threadspace
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=threadspace

# Realtime gateway. INTERNAL_TOKEN authenticates Django -> gateway publishing.
# GITHUB_WEBHOOK_SECRET must match the secret set on your GitHub webhook.
INTERNAL_TOKEN=change-me-random-token
GITHUB_WEBHOOK_SECRET=change-me-random-webhook-secret

# GitHub OAuth (sign in with GitHub + "Connect GitHub"). Use a production OAuth
# App whose Authorization callback URL is https://<DOMAIN>/github/callback.
# Since prod runs with DEBUG off, the *_PROD pair is used (the base pair, if set,
# is the fallback). The base pair is what local dev uses.
GITHUB_OAUTH_CLIENT_ID_PROD=
GITHUB_OAUTH_CLIENT_SECRET_PROD=
GITHUB_OAUTH_SCOPES=read:user,public_repo

# Optional: a GitHub token to raise the public API rate limit for repo lookups.
GITHUB_API_TOKEN=

# Encrypts secrets at rest (stored GitHub OAuth tokens). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-fernet-key
