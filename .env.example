# Copy to .env for local development. Never commit your real .env.
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Optional. Defaults to a local sqlite db when unset.
# DATABASE_URL=postgres://user:password@localhost:5432/threadspace

# Optional. A GitHub token (classic, no scopes needed) raises the public API
# rate limit used to enrich repos attached to posts.
# GITHUB_API_TOKEN=

# Optional. The Rust realtime gateway. When unset, live feed publishing is a
# no-op and the app still works. INTERNAL_TOKEN must match the gateway's.
# REALTIME_URL=http://localhost:8080
# REALTIME_INTERNAL_TOKEN=change-me-to-match-the-gateway

# GitHub OAuth (sign in with GitHub + "Connect GitHub"). Create an OAuth App at
# https://github.com/settings/developers. Use a separate app per environment,
# each with its own callback URL (<FRONTEND_URL>/github/callback):
#   - local app  -> http://localhost:3000/github/callback
#   - prod app   -> https://<DOMAIN>/github/callback
# The local pair is used when DEBUG=True; the *_PROD pair when DEBUG=False.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID_PROD=
# GITHUB_OAUTH_CLIENT_SECRET_PROD=
# GITHUB_OAUTH_SCOPES=read:user,public_repo
# FRONTEND_URL=http://localhost:3000

# Key for encrypting secrets at rest (stored OAuth tokens). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When unset, a key is derived from SECRET_KEY.
# FIELD_ENCRYPTION_KEY=

# Production hardening (leave off for local dev). Enable when serving over HTTPS.
# USE_MANIFEST_STATIC=True
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
