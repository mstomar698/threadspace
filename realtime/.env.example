# Copy to .env (loaded by your shell / process manager) for local development.

# Address to bind. Defaults to 0.0.0.0:8080.
HOST=0.0.0.0
PORT=8080

# Shared secret used to verify GitHub webhook signatures (X-Hub-Signature-256).
# Leave empty to skip verification (local development only).
GITHUB_WEBHOOK_SECRET=

# Token the Django backend must send (X-Internal-Token) to POST /internal/publish.
# Leave empty to disable auth on that endpoint (local development only).
INTERNAL_TOKEN=

# Optional: enable cross-instance fan-out via Redis pub/sub.
# Requires building with `--features redis`.
# REDIS_URL=redis://127.0.0.1:6379

# Log filter (tracing EnvFilter syntax).
RUST_LOG=info
